# Polaris — transparent AI proxy
#
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# Port the Polaris server listens on (default: 8777)
POLARIS_PORT=8777

# Upstream model provider (required)
# Examples:
#   https://api.openai.com
#   https://api.anthropic.com
#   https://api.deepseek.com
POLARIS_UPSTREAM_URL=

# API key for the upstream provider (required)
POLARIS_UPSTREAM_API_KEY=
