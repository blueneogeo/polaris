# @defaultSensitive=false
# @defaultRequired=false
# ---
# HTTP server listen port
PORT=8777

# Upstream model provider base URL (e.g. https://api.openai.com)
# @required @type=url
UPSTREAM_URL=

# API key for the upstream provider
# @required @sensitive
UPSTREAM_API_KEY=

# Base URL for Polaris's own model (the AI that judges and enhances prompts).
# Defaults to the same provider as the upstream if not set.
# @type=url
POLARIS_MODEL_URL=

# API key for Polaris's own model. Defaults to upstream key if not set.
# @sensitive
POLARIS_MODEL_API_KEY=

# Model name for Polaris's own reasoning (e.g. deepseek-chat, claude-haiku-4-5).
# Defaults to "deepseek-chat".
POLARIS_MODEL_NAME=deepseek-chat
